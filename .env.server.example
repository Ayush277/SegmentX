# MongoDB and server env example for Segment X backend
# Copy to `.env` and fill values for local development. Do NOT commit real secrets.

# MongoDB connection string (MongoDB URI)
# Example local MongoDB URI: mongodb://127.0.0.1:27017/segmentx
MONGODB_URI=mongodb://127.0.0.1:27017/segmentx

# Server port used by `server.js` (default 3000). You can override it here.
# PORT=3000
